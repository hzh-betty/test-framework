<?xml version="1.0" encoding="UTF-8"?>
<suite name="KeywordLifecycleSuite">
  <variables>
    <var name="base_url" value="https://example.test" />
    <var name="username" value="suite-user" />
    <var name="password" value="demo-pass" />
  </variables>

  <keywords>
    <keyword name="open-login-page">
      <step action="open" target="${base_url}/login" />
      <step action="wait_visible" target="id=username" value="10" />
    </keyword>
    <keyword name="fill-credentials">
      <step action="type" target="id=username" value="${username}" />
      <step action="type" target="id=password" value="${password}" />
    </keyword>
    <keyword name="submit-login">
      <step action="call" target="fill-credentials" />
      <step action="click" target="id=submit" retry="1" />
    </keyword>
  </keywords>

  <setup>
    <step action="screenshot" target="artifacts/keyword-suite-start.png" />
  </setup>

  <case name="Keyword lifecycle flow" tags="smoke,keywords" retry="1" continue_on_failure="true">
    <variables>
      <var name="username" value="case-user" />
    </variables>
    <setup>
      <step action="call" target="open-login-page" />
    </setup>
    <step action="call" target="submit-login" />
    <step action="wait_text" target="id=welcome" value="Welcome ${username}|timeout=7" continue_on_failure="true" />
    <teardown>
      <step action="screenshot" target="artifacts/keyword-case-end.png" />
    </teardown>
  </case>

  <teardown>
    <step action="screenshot" target="artifacts/keyword-suite-end.png" />
  </teardown>
</suite>
