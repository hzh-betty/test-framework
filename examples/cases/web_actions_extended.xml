<?xml version='1.0' encoding='utf-8'?>
<suite name="WebActionsExtendedSuite">
  <case name="Form and wait actions">
    <step keyword="Open">
      <arg value="https://example.test/login" />
    </step>
    <step timeout="8s" keyword="Wait Visible">
      <arg value="id=username" />
    </step>
    <step timeout="8s" keyword="Wait Clickable">
      <arg value="id=submit" />
    </step>
    <step keyword="Type Text">
      <arg value="id=username" />
      <arg value="demo" />
    </step>
    <step keyword="Type Text">
      <arg value="id=password" />
      <arg value="demo-pass" />
    </step>
    <step timeout="6s" keyword="Wait Text">
      <arg value="id=status" />
      <arg value="Ready" />
    </step>
    <step timeout="6s" keyword="Wait URL Contains">
      <arg value="/login" />
    </step>
    <step timeout="6s" keyword="Assert Element Visible">
      <arg value="id=submit" />
    </step>
    <step keyword="Assert Element Contains">
      <arg value="id=title" />
      <arg value="Welcome" />
    </step>
    <step keyword="Select">
      <arg value="id=country" />
      <arg value="China" />
    </step>
    <step keyword="Hover">
      <arg value="id=profile-menu" />
    </step>
    <step keyword="Screenshot">
      <arg value="artifacts/actions-form.png" />
    </step>
  </case>
  <case name="Context and upload actions" continue_on_failure="true">
    <step keyword="Open">
      <arg value="https://example.test/dashboard" />
    </step>
    <step keyword="Switch Frame">
      <arg value="default" />
    </step>
    <step keyword="Switch Window">
      <arg value="0" />
    </step>
    <step timeout="5s" keyword="Accept Alert" />
    <step continue_on_failure="true" keyword="Upload File">
      <arg value="id=upload" />
      <arg value="README.md" />
    </step>
    <step keyword="Screenshot">
      <arg value="artifacts/actions-context.png" />
    </step>
  </case>
</suite>