{
  "name": "SmokeSuite",
  "variables": {
    "base_url": "https://example.test",
    "username": "suite-user"
  },
  "keywords": {
    "login": [
      {
        "keyword": "Open",
        "args": [
          "${base_url}/login"
        ]
      },
      {
        "keyword": "Type Text",
        "args": [
          "id=username",
          "${username}"
        ]
      }
    ],
    "submit-login": [
      {
        "keyword": "login"
      },
      {
        "keyword": "Click",
        "args": [
          "id=submit"
        ]
      }
    ]
  },
  "cases": [
    {
      "name": "Login success",
      "variables": {
        "username": "case-user"
      },
      "steps": [
        {
          "keyword": "submit-login"
        }
      ]
    }
  ]
}
