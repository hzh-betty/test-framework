<?xml version='1.0' encoding='utf-8'?>
<suite name="SmokeSuite">
  <variables>
    <var name="base_url" value="https://example.test" />
  </variables>
  <setup>
    <step keyword="Open">
      <arg value="https://example.test/login" />
    </step>
  </setup>
  <case name="Login success" tags="smoke,login" retry="2" continue_on_failure="true">
    <variables>
      <var name="username" value="demo" />
      <var name="password" value="mode" />
    </variables>
    <setup>
      <step keyword="Wait Visible">
        <arg value="id=username" />
      </step>
    </setup>
    <step keyword="Open">
      <arg value="https://example.test/login" />
    </step>
    <step retry="3" continue_on_failure="true" keyword="Click">
      <arg value="id=submit" />
    </step>
    <teardown>
      <step keyword="Screenshot">
        <arg value="artifacts/case-end.png" />
      </step>
    </teardown>
  </case>
  <teardown>
    <step keyword="Screenshot">
      <arg value="artifacts/suite-end.png" />
    </step>
  </teardown>
</suite>