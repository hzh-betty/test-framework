<?xml version='1.0' encoding='utf-8'?>
<suite name="SmokeSuite">
  <variables>
    <var name="base_url" value="https://example.test" />
    <var name="username" value="suite-user" />
  </variables>
  <keywords>
    <keyword name="login">
      <step keyword="Open">
        <arg value="${base_url}/login" />
      </step>
      <step keyword="Type Text">
        <arg value="id=username" />
        <arg value="${username}" />
      </step>
    </keyword>
    <keyword name="submit-login">
      <step keyword="login" />
      <step keyword="Click">
        <arg value="id=submit" />
      </step>
    </keyword>
  </keywords>
  <case name="Login success">
    <variables>
      <var name="username" value="case-user" />
    </variables>
    <step keyword="submit-login" />
  </case>
</suite>