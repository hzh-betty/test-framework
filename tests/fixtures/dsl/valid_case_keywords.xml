<?xml version="1.0" encoding="UTF-8"?>
<suite name="SmokeSuite">
  <variables>
    <var name="base_url" value="https://example.test" />
    <var name="username" value="suite-user" />
  </variables>
  <keywords>
    <keyword name="login">
      <step action="open" target="${base_url}/login" />
      <step action="type" target="id=username" value="${username}" />
    </keyword>
    <keyword name="submit-login">
      <step action="call" target="login" />
      <step action="click" target="id=submit" />
    </keyword>
  </keywords>
  <case name="Login success">
    <variables>
      <var name="username" value="case-user" />
    </variables>
    <step action="call" target="submit-login" />
  </case>
</suite>
